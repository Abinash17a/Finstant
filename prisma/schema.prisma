generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model user {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  first_name             String?                  @db.VarChar(50)
  last_name              String?                  @db.VarChar(50)
  email                  String?                  @unique @db.VarChar(100)
  phone_number           String?                  @db.VarChar(20)
  password_hash          String?
  avatar_url             String?
  base_salary            Decimal?                 @db.Decimal(12, 2)
  monthly_budget         Decimal?                 @db.Decimal(12, 2)
  position               String?                  @db.VarChar(100)
  date_joined            DateTime?                @db.Timestamp(6)
  is_active              Boolean?                 @default(true)
  address                String?
  zip_code               String?                  @db.VarChar(20)
  country                String?                  @db.VarChar(50)
  birthdate              DateTime?                @db.Timestamp(6)
  created_at             DateTime?                @default(now()) @db.Timestamp(6)
  updated_at             DateTime?                @default(now()) @db.Timestamp(6)
  budget_cat_allocations budget_cat_allocations[]
  financial_goals        financial_goals[]
  monthly_summary        monthly_summary[]
  transactions           transactions[]

  @@map("users")
}

model transactions {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String    @db.Uuid
  type           String?   @db.VarChar(50)
  amount         Decimal?  @db.Decimal(12, 2)
  category       String?   @db.VarChar(100)
  description    String?
  date           DateTime? @default(now()) @db.Timestamp(6)
  payment_method String?   @db.VarChar
  location       String?
  tags           String?
  sub_category   String?   @db.VarChar
  user           user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user")

  @@index([date], map: "idx_transactions_date")
  @@index([user_id], map: "idx_transactions_user_id")
  @@map("transactions")
}

model financial_goals {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  name       String?
  target     Decimal?  @db.Decimal(12, 2)
  current    Decimal?  @db.Decimal(12, 2)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model category_colors {
  category String  @id
  color    String?
}

model budget_cat_allocations {
  id         Int       @id @default(autoincrement())
  user_id    String    @db.Uuid
  name       String?
  budget     Decimal?  @db.Decimal(12, 2)
  color      String?
  month      Int?
  year       Int?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, name, month, year], map: "unique_user_category_per_month")
  @@index([user_id], map: "idx_budget_user_id")
}

model monthly_summary {
  id           Int       @id @default(autoincrement())
  user_id      String    @db.Uuid
  month        Int?
  year         Int?
  salary       Decimal?  @db.Decimal(12, 2)
  total_budget Decimal?  @db.Decimal(12, 2)
  total_spent  Decimal?  @db.Decimal(12, 2)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  users        user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, month, year], map: "unique_summary_per_user_month")
  @@index([user_id], map: "idx_summary_user_id")
}
